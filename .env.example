# External dataset root (contains dataset/images and dataset/annotations)
# Example: E:/Data/Agriculture/AnhumasPiracicaba
SOY_DATA_ROOT=

# Optional external output directory
# Example: E:/Data/Agriculture/soy_outputs
SOY_OUTPUT_ROOT=

# Optional checkpoint directory (contains dinov3 .pth)
# Example: E:/Data/Agriculture/checkpoints
SOY_CHECKPOINT_ROOT=

# cuda or cpu
SOY_DEVICE=cuda
